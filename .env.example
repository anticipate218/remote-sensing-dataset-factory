# =============================================================
# RS Dataset Factory - Environment variables example
# 复制为 .env（不要提交到 git）后再填入真实值
# =============================================================

# -------------------------------------------------------------
# JWT (登录认证)
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
# -------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# -------------------------------------------------------------
# OpenAI 兼容 LLM（AI 助手 / GPT 精修 / AI 校正服务用）
# 任意 OpenAI 兼容端点都可以：官方 OpenAI / Azure / OpenRouter / 第三方代理 ...
# 不需要 LLM 功能可以留空，前端会显示「未配置 LLM」。
# -------------------------------------------------------------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini

# -------------------------------------------------------------
# HuggingFace 缓存（可选，建议放到大盘）
# -------------------------------------------------------------
# HF_HOME=D:/hf_cache

# -------------------------------------------------------------
# Celery / Redis（仅在大规模分布式部署时使用，单机可忽略）
# -------------------------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -------------------------------------------------------------
# Conda 环境名（start_backend.bat 会优先读取 CONDA_ENV，否则尝试 "pytorch"）
# -------------------------------------------------------------
# CONDA_ENV=pytorch
